	"scripts": {
		"test": "bun test",
		"lint": "eslint --fix",
		"db:push": "drizzle-kit push",
		"format": "prettier --write .",
		"test:watch": "bun test --watch",
		"canary": "bun upgrade --canary",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "drizzle-kit migrate",
		"deploy": "bun run VercelDeploy.ts",
		"db:generate": "drizzle-kit generate",
		"test:coverage": "bun test --coverage",
		"build": "bun db:generate && next build",
		"dev": "bun db:push && next dev --port 3000",
		"push": "bash ./pusher.sh && git push --force",
		"start": "bun db:migrate && next start --port 3000",
		"deps": "bunx playwright install chromium --with-deps",
		"upver": "bun update --latest && bun add next-auth@beta && bun add -D eslint@^9.21.0 eslint-plugin-tailwindcss@beta"
	},
	"dependencies": {
		"@auth/core": "0.34.3",
		"@auth/drizzle-adapter": "1.11.2",
